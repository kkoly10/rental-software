# Supabase (required for live data, auth, and order creation)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public canonical site URL used for auth redirects and request-origin validation.
# In local development, keep this at localhost. In production, set it to your live domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deprecated: NEXT_PUBLIC_APP_URL is no longer used.

# App domain for subdomain/tenant routing (e.g., korent.app).
# Subdomains like acme.korent.app resolve to the "acme" organization.
# Defaults to localhost:3000 in development.
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
# Marketplace hostname (spec §31 launch decision: rent.korent.app).
# Requests to this host are rewritten to the /market route group by the
# middleware. Unset = marketplace reachable only at /market paths.
NEXT_PUBLIC_MARKETPLACE_HOST=rent.korent.app

# Server-only Supabase service role key.
# Required for DB-backed rate limiting and other secure server-side tasks.
# Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY=

# The app runs in demo/fallback mode without the public Supabase variables.
# All pages render with mock data so you can preview the full UI
# without a Supabase project.
# Optional public storage bucket for product catalog images
NEXT_PUBLIC_SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
# Storage bucket for crew proof-of-delivery photos and file uploads
NEXT_PUBLIC_SUPABASE_UPLOADS_BUCKET=uploads

# AI Copilot (optional — enables AI-powered operator assistant)
# Provide ONE of these keys. Without either, Copilot uses built-in knowledge base.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe (required for subscription billing)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional emails — order confirmations, payment receipts, etc.)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# Optional: custom FROM address (must be verified in Resend)
# EMAIL_FROM_ADDRESS=YourBusiness <noreply@yourdomain.com>

# Twilio (optional — SMS notifications for order updates, delivery alerts, etc.)
# Without these, SMS features run in demo mode (messages logged, not sent).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Sentry (optional — error monitoring and performance tracking)
# Get your DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
# NEXT_PUBLIC_SENTRY_DSN=

# Stripe subscription price IDs (run scripts/stripe-seed.sh to generate)
# STRIPE_STARTER_MONTHLY_PRICE_ID=
# STRIPE_STARTER_YEARLY_PRICE_ID=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=
# STRIPE_GROWTH_MONTHLY_PRICE_ID=
# STRIPE_GROWTH_YEARLY_PRICE_ID=

# QuickBooks Online (optional — push paid invoices into QBO for accounting)
# Without these, the QBO integration card on Settings → Integrations
# shows as 'not configured' and no sync runs.
# Get credentials by creating an app at https://developer.intuit.com
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
# QBO_ENVIRONMENT=sandbox


# Xero (optional — push paid invoices into Xero for accounting)
# Without these, the Xero card on Settings → Integrations shows as
# 'not configured' and no sync runs.
# Get credentials from https://developer.xero.com → My Apps
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=http://localhost:3000/api/integrations/xero/callback


# WhatsApp Business (optional — Sprint 4)
# Twilio acts as WhatsApp BSP. Same TWILIO_ACCOUNT_SID + AUTH_TOKEN as
# SMS. The per-template ContentSid is created in the Twilio console
# after Meta approves the template.
# WHATSAPP_TEMPLATE_ORDER_CONFIRMATION=
# WHATSAPP_TEMPLATE_DEPOSIT_REMINDER=
# WHATSAPP_TEMPLATE_DELIVERY_SCHEDULED=
# WHATSAPP_TEMPLATE_DELIVERY_EN_ROUTE=
# WHATSAPP_TEMPLATE_DELIVERY_COMPLETED=
# WHATSAPP_TEMPLATE_WEATHER_ALERT=
# WHATSAPP_TEMPLATE_PAYMENT_RECEIVED=


# Mapbox (optional — Sprint 5 route auto-optimization)
# Get a token from https://account.mapbox.com/access-tokens/
# Free tier: 50k optimization requests/month. Paid: $2/1k after that.
# MAPBOX_ACCESS_TOKEN=

# Cron job authorization (required when deploying behind Vercel cron).
# Vercel sends this as the Authorization header on scheduled invocations.
# Generate a random value (e.g. `openssl rand -hex 32`) and paste it both
# here and into Vercel's encrypted env vars. Without it, every cron route
# rejects requests — which is what you want in any environment that's
# not behind Vercel cron.
# CRON_SECRET=

# Email "view in browser" HMAC key. Signs the tokens that let customers
# open a portal-mail view of past emails. Without it the link generator
# falls back to an unsigned mode and rotates aggressively, which means
# bookmarked links expire faster than expected. Generate with
# `openssl rand -hex 32`.
# EMAIL_VIEW_SECRET=

# Customer portal access token lifetime in days. Controls how long the
# magic-link / order-status token remains valid after issuance.
# Defaults to 90 days; lower for higher-security operators.
# PORTAL_TOKEN_MAX_AGE_DAYS=90

# Customer PII retention window (days). Past this, the nightly purge
# cron clears phone, email, and address from cancelled/completed orders
# older than the window. Defaults align with the platform privacy policy.
# PII_PURGE_RETENTION_DAYS=

# Server-only fallback for the canonical site URL. Used by cron jobs and
# background tasks that run outside of an HTTP request, where
# NEXT_PUBLIC_SITE_URL may not be reachable from the runtime. Set to the
# same value as NEXT_PUBLIC_SITE_URL in production.
# SITE_URL=
